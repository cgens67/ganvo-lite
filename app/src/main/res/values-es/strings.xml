    <string name="visitor_data_info_title">¿Qué es VISITOR_DATA?</string>
    <string name="visitor_data_info_intro">VISITOR_DATA es un identificador utilizado por YouTube para realizar un seguimiento de tu sesión. Cuando se corrompe, puede causar:</string>
    <string name="visitor_data_info_problems">• Errores de conectividad\n• Problemas al cargar contenido\n• Fallos en la búsqueda\n• Interrupciones en la reproducción</string>
    <string name="visitor_data_info_solution">Restablecer VISITOR_DATA genera un nuevo identificador y generalmente resuelve estos problemas.</string>
    <string name="visitor_data_info_note">Esto funciona tanto para usuarios anónimos como para usuarios que han iniciado sesión.</string>
    <string name="visitor_data_info_confirm">Entendido</string>

